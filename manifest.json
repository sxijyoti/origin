{
  "manifest_version": 3,
  "name": "Origin",
  "version": "1.0.0",
  "description": "Offline-first terminal new tab dashboard",
  "permissions": ["storage", "bookmarks", "history", "tabs"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
